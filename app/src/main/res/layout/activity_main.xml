<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#FFFFFF">

    <!-- 搜索框（保持不变） -->
    <EditText
        android:id="@+id/et_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/search_hint"
        android:padding="12dp"
        android:background="#f0f2f5"
        android:textColor="#333333"
        android:textColorHint="#666666"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- 筛选器（保持不变） -->
    <HorizontalScrollView
        android:id="@+id/scroll_filter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/et_search"
        android:background="@drawable/rounded_bottom_only">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="0dp">

            <Button
                android:id="@+id/filter_type"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:textSize="12sp"
                android:layout_marginHorizontal="4dp"/>

            <Button
                android:id="@+id/filter_gender"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:textSize="12sp"
                android:layout_marginHorizontal="4dp"/>

            <Button
                android:id="@+id/filter_finance"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:textSize="12sp"
                android:layout_marginHorizontal="4dp"/>

            <Button
                android:id="@+id/filter_favorite"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:textSize="12sp"
                android:layout_marginHorizontal="4dp"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- ================== 核心修改：列表+地图 55开 ================== -->
    <LinearLayout
        android:id="@+id/layout_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/scroll_filter"
        app:layout_constraintBottom_toTopOf="@id/layout_pagination">

        <!-- 学校列表（左50%） -->
        <ListView
            android:id="@+id/list_view"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#ffffff"
            android:divider="#ffffff"
            android:dividerHeight="16dp"
            android:clipToPadding="false"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:scrollbarStyle="outsideInset"/>

        <!-- 地图（右50%） -->
        <fragment
            android:id="@+id/map"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>

    </LinearLayout>

    <!-- 无结果提示（调整约束，与内容区域重叠） -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:text="暫無相關學校"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="20dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/scroll_filter"
        app:layout_constraintBottom_toTopOf="@id/layout_pagination"/>

    <!-- 分页栏（保持不变） -->
    <LinearLayout
        android:id="@+id/layout_pagination"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/rounded_top_only"
        android:padding="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_prev"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/prev_page"
            android:textSize="11sp"/>

        <Button
            android:id="@+id/page_btn1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"/>

        <Button
            android:id="@+id/page_btn2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"/>

        <Button
            android:id="@+id/page_btn3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"/>

        <Button
            android:id="@+id/page_btn4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"/>

        <Button
            android:id="@+id/page_btn5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"/>

        <Button
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/next_page"
            android:textSize="11sp"/>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>