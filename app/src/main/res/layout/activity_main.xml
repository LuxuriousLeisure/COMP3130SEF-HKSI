<?xml version="1.0" encoding="utf-8"?>
<!-- 根布局：垂直排列 → 上面列表，下面分页栏 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- 搜索框（引用字符串资源，Lab02规范） -->
    <EditText
        android:id="@+id/et_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/search_hint"
        android:padding="8dp"/>

    <!-- 筛选器 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <!-- 筛选1：学校类型 -->
            <Button
                android:id="@+id/filter_type"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="學校類型"
                android:textSize="12sp"
                android:layout_marginHorizontal="4dp"/>

            <!-- 筛选2：学生性别 -->
            <Button
                android:id="@+id/filter_gender"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="學生性別"
                android:textSize="12sp"
                android:layout_marginHorizontal="4dp"/>

            <!-- 筛选3：资助种类 -->
            <Button
                android:id="@+id/filter_finance"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="資助種類"
                android:textSize="12sp"
                android:layout_marginHorizontal="4dp"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- 学校列表 -->
    <ListView
        android:id="@+id/list_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#ffffff"
        android:divider="#ffffff"
        android:dividerHeight="16dp"
        android:clipToPadding="false"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:scrollbarStyle="outsideInset"/>

    <!-- 搜尋無結果提示 -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="暫無相關學校"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="20dp"
        android:visibility="gone"/> <!-- 預設隱藏 -->

    <!-- ================== 分页栏（文字全部引用strings.xml） ================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#f5f5f5"
        android:padding="6dp">

        <!-- 上一页 -->
        <Button
            android:id="@+id/btn_prev"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/prev_page"
            android:textSize="11sp"/>

        <!-- 页码1 -->
        <Button
            android:id="@+id/page_btn1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"/>

        <!-- 页码2 -->
        <Button
            android:id="@+id/page_btn2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"/>

        <!-- 页码3 -->
        <Button
            android:id="@+id/page_btn3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"/>

        <!-- 页码4 -->
        <Button
            android:id="@+id/page_btn4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"/>

        <!-- 页码5 -->
        <Button
            android:id="@+id/page_btn5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"/>

        <!-- 下一页 -->
        <Button
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/next_page"
            android:textSize="11sp"/>

    </LinearLayout>

</LinearLayout>